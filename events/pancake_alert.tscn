[sub_resource type="GDScript" id="GDScript_le437"]
resource_name = "event_controller"
script/source = "extends Node

signal called_to_clear()

@export var popup : Window
@export var glitch : Window
@export var cry_sound : AudioStreamPlayer
@export var glitch_sound : AudioStreamPlayer
@export var eat_sound : AudioStreamPlayer
@export var timer : Timer
@onready var event : Event = get_parent()

var eventing = false
var _anim_state = 0;

func _ready() -> void:
	popup.no_button_pressed.connect(press_no)
	popup.yes_button_pressed.connect(func ():
		print(\"pressed yes\")
		play_eating_anim()
		#GlobalControlls.doned_events += 1
		if not AchievementsController.IsAchievementTaked(\"time_to_dinner\"):
			AchievementsController.TakeAchievement(\"time_to_dinner\", true)
	)
	cry_sound.finished.connect(func ():
		if not AchievementsController.IsAchievementTaked(\"worst_friend\"):
			Dialog.show_dialog(\"PANCAKE_ALERT_DIALOG_A\", null, 0.05, true)
			Dialog.dialog_skiped.connect(func ():
				Dialog.show_dialog(\"PANCAKE_ALERT_DIALOG_B\", null, 0.05, true)
				Dialog.dialog_skiped.connect(func ():
					Dialog.show_dialog(\"PANCAKE_ALERT_DIALOG_C\", null, 0.05, true)
					Dialog.dialog_skiped.connect(func ():
						glitch.visible = true
						glitch_sound.finished.connect(func ():
							glitch.visible = false
							ValuesContainer.ForceFacepic(\"pancakes\")
							AchievementsController.TakeAchievement(\"worst_friend\", true)
							popup.popup()
						, CONNECT_ONE_SHOT)
						glitch_sound.play()
					, CONNECT_ONE_SHOT)
				, CONNECT_ONE_SHOT)
			, CONNECT_ONE_SHOT)
		else:
			Dialog.show_dialog(\"[ ... ]\", null, 0.05, true)
			Dialog.dialog_skiped.connect(func ():
				glitch.visible = true
				glitch_sound.finished.connect(func ():
					glitch.visible = false
					ValuesContainer.ForceFacepic(\"pancakes\")
					popup.popup()
				, CONNECT_ONE_SHOT)
				glitch_sound.play()
			, CONNECT_ONE_SHOT)
	)

func do_event() -> void:
	if not eventing:
		eventing = true
		popup.popup()
		ValuesContainer.ForceFacepic(\"pancakes\")

func revert():
	ValuesContainer.UnforceFacepic()
	called_to_clear.emit()

func play_eating_anim():
	eat_sound.play()
	timer.timeout.connect(anim_step)
	timer.start()

func anim_step():
	match _anim_state:
		0: ValuesContainer.ForceFacepic(\"eat1\")
		1: ValuesContainer.ForceFacepic(\"eat2\")
		2: ValuesContainer.ForceFacepic(\"eat1\")
		3: ValuesContainer.ForceFacepic(\"eat2\")
		4: ValuesContainer.ForceFacepic(\"eat1\")
		5: ValuesContainer.ForceFacepic(\"eat2\")
		6: ValuesContainer.ForceFacepic(\"eat1\")
		7: revert()
	_anim_state += 1

func press_no():
	print(\"pressed no\")
	ValuesContainer.ForceFacepic(\"super_cry\")
	cry_sound.play()
"

[sub_resource type="GDScript" id="GDScript_4vcw5"]
resource_name = "scary_effect_window"
script/source = "extends Window

@export var texture_rect : TextureRect

func _ready() -> void:
	visible = false
	visibility_changed.connect(func ():
		if visible:
			var main_window_screen = DisplayServer.window_get_current_screen(DisplayServer.MAIN_WINDOW_ID)
			position = DisplayServer.screen_get_position(main_window_screen)
			size = DisplayServer.screen_get_size(main_window_screen) + Vector2i(1,1)
			texture_rect.texture = ImageTexture.create_from_image(DisplayServer.screen_get_image(main_window_screen))
			texture_rect.material.set_shader_parameter(\"offset_power\", 0)
			WindowExstantions.UpdateWindowsExStyles(self, true, true)
	)

func _process(delta: float) -> void:
	if visible:
		texture_rect.material.set_shader_parameter(\"offset_power\", texture_rect.material.get_shader_parameter(\"offset_power\") - delta * 0.05)
#		if texture_rect.material.get_shader_parameter(\"offset_power\") <= -0.03:
#			visible = false
"

