[sub_resource type="GDScript" id="GDScript_wdcdh"]
resource_name = "screen_break_controller"
script/source = "extends Node

const blocks_size := Vector2i(5,6)

var hex_solved := false
var block_solved := false

@export var squares_death : AudioStreamPlayer
@export var glitch_sound : AudioStreamPlayer
@export var sounds : Array[AudioStream]

@export var hex_puzzle_window : Window
@export var hex_bits : Array[Node]
@export var hex_target_label : Label
@export var hex_result_label : Label
@export var hex_result2_label : Label
@export var hex_output : Label
@export var hex_squares_emmiter : GPUParticles2D;
var hex_target = 0;

@export var block_puzzle_window : Window
@export var blocks_bitmap : BitMap
@export var blocks_count : int
@export var block_show_sound : AudioStreamPlayer
@export var block_press_sound : AudioStreamPlayer
@export var block_template : PackedScene
@export var blocks_container : GridContainer
@export var blocks_fake_container : GridContainer
@export var blocks_squares_emmiter : GPUParticles2D;
var block_bitmap_offset : Vector2i
var blocks_checks : Array[bool] = []

func _ready() -> void:
	block_puzzle_window.visible = false
	for hex_bit in hex_bits:
		hex_bit.value_changed.connect(func ():
			hex_update()
		)

func do_event() -> void:
	glitch_sound.stream = sounds.pick_random()
	glitch_sound.play()
	
	var screen_size := DisplayServer.screen_get_size(DisplayServer.SCREEN_OF_MAIN_WINDOW)
	var position : Vector2i = Vector2i(0, 0)
	position.x = randi_range(0, screen_size.x - hex_puzzle_window.size.x)
	position.y = randi_range(0, screen_size.y - hex_puzzle_window.size.y)
	hex_puzzle_window.position = DisplayServer.screen_get_position(DisplayServer.SCREEN_OF_MAIN_WINDOW) + position
	hex_target = randi_range(1, 255)
	hex_target_label.text = str(hex_target)
	
	@warning_ignore(\"integer_division\")
	block_bitmap_offset = Vector2i(randi_range(1, blocks_bitmap.get_size().x / blocks_size.x) - 1, randi_range(1, blocks_bitmap.get_size().y / blocks_size.y) - 1) * blocks_size

func hex_update() -> void:
	var count := 0
	for i in range(len(hex_bits)):
		count += pow(2, i) * hex_bits[i].current_symbol
	hex_result_label.text = str(count)
	hex_result2_label.text = hex_result_label.text
	hex_output.text = str(count == hex_target)
	if (count == hex_target and not hex_solved):
		hex_solved = true
		squares_death.play()
		hex_squares_emmiter.emitting = false
		get_tree().create_timer(1.5).timeout.connect(blocks)

func blocks() -> void:
	hex_puzzle_window.hide()
	glitch_sound.stream = sounds.pick_random()
	glitch_sound.play()
	
	var screen_size := DisplayServer.screen_get_size(DisplayServer.SCREEN_OF_MAIN_WINDOW)
	var position : Vector2i = Vector2i(0, 0)
	position.x = randi_range(0, screen_size.x - block_puzzle_window.size.x)
	position.y = randi_range(0, screen_size.y - block_puzzle_window.size.y)
	block_puzzle_window.position = DisplayServer.screen_get_position(DisplayServer.SCREEN_OF_MAIN_WINDOW) + position
	block_puzzle_window.visible = true
	
	blocks_container.columns = blocks_size.x
	for y in range(blocks_size.y):
		for x in range(blocks_size.x):
			await get_tree().create_timer(0.1).timeout
			var block : Control = block_template.instantiate()
			blocks_container.add_child(block)
			var texture : CanvasItem = block.get_node(\"TextureRect\")
			block.gui_input.connect(func (event : InputEvent):
				if event is InputEventMouseButton:
					if event.button_index == MOUSE_BUTTON_LEFT:
						if event.pressed:
							texture.visible = not texture.visible
							blocks_checks[y * blocks_size.x + x] = texture.visible == blocks_bitmap.get_bit(x + block_bitmap_offset.x, y + block_bitmap_offset.y)
							block_press_sound.play()
							blocks_update()
			)
			blocks_checks.append(texture.visible == blocks_bitmap.get_bit(x + block_bitmap_offset.x, y + block_bitmap_offset.y))
			
			var fake_block : Control = block_template.instantiate()
			blocks_fake_container.add_child(fake_block)
			fake_block.get_node(\"TextureRect\").visible = blocks_bitmap.get_bit(x + block_bitmap_offset.x, y + block_bitmap_offset.y)
			
			block_show_sound.play()

func blocks_update() -> void:
	#print(\"----------\")
	var can_continue := true
	for b in blocks_checks:
		#print(b)
		if not b:
			can_continue = false
			break
	if (can_continue and not block_solved):
		block_solved = true
		squares_death.play()
		blocks_squares_emmiter.emitting = false
		blocks_fake_container.visible = false
		get_tree().create_timer(1.5).timeout.connect(func():
			block_puzzle_window.hide()
		)
		await squares_death.finished
		ValuesContainer.DonedEvents += 1
		get_parent().emit_signal(\"event_ended\")
"

